{
  "expo": {
    "name": "Hobi",
    "slug": "hobi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hobiIcon.png",
    "scheme": "hobi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/hobiIcon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/hobiIcon.png",
        "backgroundImage": "./assets/images/hobiIcon.png",
        "monochromeImage": "./assets/images/hobiIcon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.samuuuxp.hobi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/hobiIcon.png",
            "imageWidth": 150
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Necesitamos acceso a tu cámara para subir el reto."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/hobiIcon.png",
          "color": "#208AEF",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "90828f64-beab-400c-8c86-ea81613744ff"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/90828f64-beab-400c-8c86-ea81613744ff",
      "requestHeaders": {
        "expo-channel": "production"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}