{
  "expo": {
    "name": "Hobi",
    "slug": "hobi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hobiIcon.png",
    "scheme": "hobi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/hobiIcon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/hobiIcon.png",
        "backgroundImage": "./assets/images/hobiIcon.png",
        "monochromeImage": "./assets/images/hobiIcon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.samuuuxp.hobi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Necesitamos acceso a tu cámara para subir el reto."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "https://lywureazxewyujvjfrcx.supabase.co",
      "supabaseAnonKey": "sb_publishable_eVdP92MbyxJi1h8ZMS78BA_3YG2rCmK",
      "router": {},
      "eas": {
        "projectId": "90828f64-beab-400c-8c86-ea81613744ff"
      }
    }
  }
}